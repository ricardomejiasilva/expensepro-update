{
    "name": "expense-pro",
    "version": "1.0.7",
    "scripts": {
        "start": "expo start --dev-client",
        "start-dev": "npx expo start --dev-client --tunnel",
        "start-prod": "expo start --no-dev --minify",
        "start-prod-no-dev-client": "NODE_ENV=production expo start --no-dev --minify",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "web": "expo start --web",
        "build-ios": "eas build --profile development --platform ios",
        "build-dev-local": "eas build --profile=development --platform ios --local",
        "build-android": "eas build --profile development --platform android",
        "build-preview": "eas build --profile preview --platform ios",
        "build-preview-android": "eas build --profile preview --platform android",
        "build-preview-local": "eas build --profile preview --platform ios --local",
        "build-prod": "eas build -p ios",
        "build-prod-android": "eas build -p android",
        "build-sim": "eas build -p ios --profile simulator",
        "build-sim-dev": "eas build -p ios --profile simulator-dev",
        "deploy-ios": "eas submit --platform ios",
        "deploy-android": "eas submit --platform android"
    },
    "dependencies": {
        "@expo-google-fonts/dm-sans": "^0.2.3",
        "@expo/vector-icons": "^14.0.3",
        "@react-native-async-storage/async-storage": "1.23.1",
        "@react-native-community/datetimepicker": "8.2.0",
        "@react-native-community/masked-view": "^0.1.11",
        "@react-native-cookies/cookies": "^6.2.1",
        "@react-native-firebase/analytics": "^22.2.1",
        "@react-native-firebase/app": "^22.2.1",
        "@react-native-firebase/crashlytics": "^22.2.1",
        "@react-navigation/bottom-tabs": "^6.5.20",
        "@react-navigation/native": "^6.1.17",
        "@react-navigation/native-stack": "^6.9.26",
        "@sentry/react-native": "~6.3.0",
        "@tanstack/react-query": "^5.59.20",
        "dayjs": "^1.11.13",
        "expo": "^52.0.37",
        "expo-build-properties": "~0.13.3",
        "expo-constants": "~17.0.7",
        "expo-dev-client": "~5.0.20",
        "expo-device": "~7.0.2",
        "expo-doctor": "^1.12.1",
        "expo-document-picker": "~13.0.3",
        "expo-file-system": "~18.0.12",
        "expo-image-manipulator": "~13.0.6",
        "expo-image-picker": "~16.0.6",
        "expo-linear-gradient": "~14.0.2",
        "expo-modules-core": "^2.5.0",
        "expo-notifications": "~0.29.13",
        "expo-status-bar": "~2.0.1",
        "expo-tracking-transparency": "~5.1.1",
        "expo-updates": "~0.27.1",
        "react": "18.3.1",
        "react-native": "0.76.7",
        "react-native-async-storage": "^0.0.1",
        "react-native-blob-util": "^0.19.11",
        "react-native-date-picker": "^5.0.7",
        "react-native-gesture-handler": "~2.20.2",
        "react-native-modal-datetime-picker": "^7.6.1",
        "react-native-pdf": "^6.7.5",
        "react-native-reanimated": "~3.16.1",
        "react-native-responsive-fontsize": "^0.5.1",
        "react-native-responsive-screen": "^1.4.2",
        "react-native-safe-area-context": "4.12.0",
        "react-native-screens": "~4.4.0",
        "react-native-scripts": "^2.0.1",
        "react-native-svg": "15.8.0",
        "react-native-svg-transformer": "^1.5.0",
        "react-native-ui-datepicker": "2.0.4",
        "react-native-vector-icons": "^9.2.0",
        "react-native-view-shot": "^4.0.3",
        "react-native-webview": "13.12.5",
        "react-navigation": "^4.4.4",
        "react-navigation-stack": "^2.10.4",
        "sentry-expo": "~7.0.0",
        "typescript": "~5.3.3",
        "uri-scheme": "^1.2.2"
    },
    "devDependencies": {
        "@babel/core": "^7.24.0",
        "@react-native-community/cli": "^15.1.2",
        "@types/react": "^18.2.79",
        "@types/react-native": "^0.73.0",
        "@typescript-eslint/eslint-plugin": "^7.17.0",
        "@typescript-eslint/parser": "^7.17.0",
        "babel-plugin-module-resolver": "^5.0.2"
    },
    "resolutions": {
        "react-native-reanimated": "3.16.1"
    },
    "private": true,
    "bundleDependencies": [
        "expo",
        "react-native",
        "react-native-scripts"
    ]
}
